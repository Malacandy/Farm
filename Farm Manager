<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FarmTrack Malawi</title>
    <!-- PWA Manifest -->
    <link rel="manifest" href="data:application/manifest+json,{'name':'FarmTrack','short_name':'FarmTrack','start_url':'.','display':'standalone','background_color':'#f0f2f5','theme_color':'#2e7d32'}">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .card { background: white; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .bg-farm { background-color: #2e7d32; }
        .mwk::before { content: "MK "; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen pb-20">

    <!-- Header -->
    <header class="bg-farm text-white p-4 shadow-lg sticky top-0 z-10">
        <h1 class="text-xl font-bold">FarmTrack Malawi</h1>
    </header>

    <div id="app" class="p-4 max-w-md mx-auto">
        <!-- Dashboard / Profit First Accounts -->
        <section class="mb-6">
            <h2 class="text-lg font-bold mb-3 text-gray-700">Financial Overview (Profit First)</h2>
            <div class="grid grid-cols-2 gap-3">
                <div class="card p-3 border-l-4 border-blue-500">
                    <p class="text-xs text-gray-500 uppercase">Operation Account</p>
                    <p class="font-bold mwk" id="acc-op">0</p>
                </div>
                <div class="card p-3 border-l-4 border-green-500">
                    <p class="text-xs text-gray-500 uppercase">Profit Account</p>
                    <p class="font-bold mwk" id="acc-profit">0</p>
                </div>
                <div class="card p-3 border-l-4 border-yellow-500">
                    <p class="text-xs text-gray-500 uppercase">My Salary</p>
                    <p class="font-bold mwk" id="acc-salary">0</p>
                </div>
                <div class="card p-3 border-l-4 border-purple-500">
                    <p class="text-xs text-gray-500 uppercase">Tax/Reserve</p>
                    <p class="font-bold mwk" id="acc-tax">0</p>
                </div>
            </div>
        </section>

        <!-- Crops List -->
        <section>
            <div class="flex justify-between items-center mb-3">
                <h2 class="text-lg font-bold text-gray-700">My Crops</h2>
                <button onclick="addCrop()" class="bg-farm text-white px-3 py-1 rounded-full text-sm">+ Add Crop</button>
            </div>
            <div id="crop-list" class="grid grid-cols-1 gap-3">
                <!-- Crops will be injected here -->
            </div>
        </section>
    </div>

    <!-- Modal for Detail (Hidden by default) -->
    <div id="modal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-20 p-4">
        <div class="bg-white rounded-lg h-full overflow-y-auto p-4">
            <div class="flex justify-between border-b pb-2 mb-4">
                <h2 id="modal-title" class="text-xl font-bold text-farm"></h2>
                <button onclick="closeModal()" class="text-gray-500 text-2xl">&times;</button>
            </div>
            
            <div class="space-y-6">
                <!-- Inputs Section -->
                <div>
                    <h3 class="font-bold text-gray-600 mb-2">Farm Inputs & Costs</h3>
                    <div id="input-list" class="text-sm space-y-1 mb-2"></div>
                    <button onclick="addEntry('input')" class="w-full border border-farm text-farm py-1 rounded">+ Add Input</button>
                </div>

                <!-- Activities Section -->
                <div>
                    <h3 class="font-bold text-gray-600 mb-2">Activities (Tilling, etc.)</h3>
                    <div id="activity-list" class="text-sm space-y-1 mb-2"></div>
                    <button onclick="addEntry('activity')" class="w-full border border-farm text-farm py-1 rounded">+ Add Activity</button>
                </div>

                <!-- Harvest Section -->
                <div class="bg-green-50 p-3 rounded-lg">
                    <h3 class="font-bold text-green-800 mb-2">Harvest & Sales</h3>
                    <div id="harvest-list" class="text-sm space-y-1 mb-2"></div>
                    <button onclick="addEntry('harvest')" class="w-full bg-farm text-white py-2 rounded">Record Sale & Allocate Profit</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        let db = JSON.parse(localStorage.getItem('farmDB')) || {
            crops: [
                { id: 1, name: 'Tomatoes', inputs: [], activities: [], harvests: [] },
                { id: 2, name: 'Onions', inputs: [], activities: [], harvests: [] },
                { id: 3, name: 'Maize', inputs: [], activities: [], harvests: [] }
            ],
            accounts: { op: 0, profit: 0, salary: 0, tax: 0 }
        };

        let currentCropId = null;

        function saveData() {
            localStorage.setItem('farmDB', JSON.stringify(db));
            render();
        }

        function render() {
            const list = document.getElementById('crop-list');
            list.innerHTML = '';
            db.crops.forEach(crop => {
                const totalCost = [...crop.inputs, ...crop.activities].reduce((sum, item) => sum + item.cost, 0);
                list.innerHTML += `
                    <div class="card p-4 flex justify-between items-center" onclick="openCrop(${crop.id})">
                        <div>
                            <h3 class="font-bold text-lg">${crop.name}</h3>
                            <p class="text-xs text-gray-400">Total Spent: MK ${totalCost.toLocaleString()}</p>
                        </div>
                        <span class="text-farm font-bold">→</span>
                    </div>
                `;
            });

            document.getElementById('acc-op').innerText = db.accounts.op.toLocaleString();
            document.getElementById('acc-profit').innerText = db.accounts.profit.toLocaleString();
            document.getElementById('acc-salary').innerText = db.accounts.salary.toLocaleString();
            document.getElementById('acc-tax').innerText = db.accounts.tax.toLocaleString();
        }

        function addCrop() {
            const name = prompt("Enter crop name:");
            if (name) {
                db.crops.push({ id: Date.now(), name, inputs: [], activities: [], harvests: [] });
                saveData();
            }
        }

        function openCrop(id) {
            currentCropId = id;
            const crop = db.crops.find(c => c.id === id);
            document.getElementById('modal-title').innerText = crop.name;
            
            document.getElementById('input-list').innerHTML = crop.inputs.map(i => `<div>${i.desc}: <span class="mwk font-bold">${i.cost}</span></div>`).join('');
            document.getElementById('activity-list').innerHTML = crop.activities.map(i => `<div>${i.desc}: <span class="mwk font-bold">${i.cost}</span></div>`).join('');
            document.getElementById('harvest-list').innerHTML = crop.harvests.map(i => `<div class="border-b py-1">Sold: <span class="mwk font-bold">${i.cost}</span> (${i.desc})</div>`).join('');
            
            document.getElementById('modal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('modal').classList.add('hidden');
        }

        function addEntry(type) {
            const crop = db.crops.find(c => c.id === currentCropId);
            const desc = prompt(`Enter ${type} description:`);
            const cost = parseFloat(prompt("Enter amount (MK):"));

            if (desc && !isNaN(cost)) {
                if (type === 'input') crop.inputs.push({ desc, cost, date: new Date() });
                if (type === 'activity') crop.activities.push({ desc, cost, date: new Date() });
                if (type === 'harvest') {
                    crop.harvests.push({ desc, cost, date: new Date() });
                    // Profit First Allocation Logic
                    db.accounts.op += (cost * 0.50);     // 50% to operations
                    db.accounts.profit += (cost * 0.10); // 10% to owners profit
                    db.accounts.salary += (cost * 0.30); // 30% to salary
                    db.accounts.tax += (cost * 0.10);    // 10% to reserve
                }
                saveData();
                openCrop(currentCropId); // refresh modal
            }
        }

        render();
    </script>
</body>
</html>
